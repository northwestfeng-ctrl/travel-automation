# 复制为 travel_automation.local.env 后填写敏感配置
# 非敏感默认配置保留在 travel_automation.env 中

FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_USER_OPEN_ID=your_target_open_id
MINIMAX_API_KEY=your_minimax_api_key

TRAVEL_PLAN_START_OFFSET_DAYS=1
TRAVEL_PLAN_END_OFFSET_DAYS=2

TRAVEL_AUTO_REPLY_ENABLED=1
TRAVEL_AUTO_REPLY_ACCOUNTS=hotel_1164390341,hotel_95267083

TRAVEL_APPROVAL_NOTIFY=1
TRAVEL_APPROVAL_COMMIT=1

TRAVEL_APPROVAL_MAX_AGE_HOURS=48
TRAVEL_APPROVAL_MAX_OPS=20
TRAVEL_APPROVAL_LIMIT=20

# 可选：覆盖竞品抓取结果目录。默认使用项目内 competitor-analysis/results。
# COMPETITOR_RESULTS_DIR=competitor-analysis/results

# 可选：覆盖携程 ebooking Playwright storage-state。默认使用 ~/.openclaw/credentials/ctrip-ebooking-auth.json。
# CTRIP_STORAGE_STATE=~/.openclaw/credentials/ctrip-ebooking-auth.json

# 可选：抓包调试脚本输出文件。默认写入 pricing/artifacts/ 下带时间戳的文件，避免互相覆盖。
# CTRIP_CAPTURED_REQUESTS_FILE=/tmp/captured_requests.json
